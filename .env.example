# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
# Set to your Render URL in production: https://nexus.onrender.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Redis (optional — leave blank to use in-memory Socket.io) ───────────────
REDIS_URL=

# ─── Email (Resend — free at resend.com) ─────────────────────────────────────
RESEND_API_KEY=re_your_api_key
# Dev: onboarding@resend.dev  |  Prod: Nexus <noreply@yourdomain.com>
EMAIL_FROM=Nexus <onboarding@resend.dev>

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-64-char-hex-secret
